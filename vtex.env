# configures NextJS
NEXT_TELEMETRY_DISABLED=true

# configures WebOps
## Enable re-using node_modules from previous runs for faster builds
USE_BUILD_CACHE=true

## Enable Incremental Static Builds (ISB):
## https://www.faststore.dev/releases/2022/05/19/webops
USE_STALE_CACHE=true

## Production site host your users will
## access your website
# SITE_HOST=demo.faststore.dev


NEXT_PUBLIC_CHECKOUT_URL=https://voryn.myvtex.com/checkout/#/cart

NEXT_PUBLIC_VTEX_ACCOUNT=voryn
NEXT_PUBLIC_STORE_ID=voryn
NEXT_PUBLIC_VTEX_WORKSPACE=master
NEXT_PUBLIC_VTEX_ENVIRONMENT=myvtex
NEXT_PUBLIC_SALES_CHANNEL=1